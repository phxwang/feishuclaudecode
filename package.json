{
  "name": "feishuchannel-for-claudecode",
  "version": "0.3.0",
  "description": "Feishu (Lark) channel plugin for Claude Code — route multiple groups to isolated Claude instances via a single bot",
  "license": "MIT",
  "type": "module",
  "bin": {
    "feishuchannel-for-claudecode": "./bin/install.js"
  },
  "scripts": {
    "start": "bun install --no-summary && bun server.ts",
    "router": "bun install --no-summary && bun router.ts",
    "postinstall": "mkdir -p ~/.local/bin && ln -sf \"$(pwd)/bin/claude-feishu\" ~/.local/bin/claude-feishu"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@larksuiteoapi/node-sdk": "^1.5.0",
    "zod": "^3.22.0"
  }
}
